# ============================================
# AI Tutor 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置
# ============================================

# 应用配置
APP_NAME=AI Tutor
APP_VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置 - MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=ai_tutor

# 数据库配置 - Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# LLM配置 - 硅基流动 (SiliconFlow)
# 文档: https://docs.siliconflow.cn/
# ============================================

OPENAI_API_KEY=your-siliconflow-api-key
OPENAI_API_BASE=https://api.siliconflow.cn/v1

# 🎯 主模型 - 数学辅导专用
# 推荐选项（按数学能力排序）:
# 1. deepseek-ai/DeepSeek-R1 - 最强推理能力，适合复杂数学题 ⭐推荐
# 2. Qwen/Qwen2.5-72B-Instruct - 通用能力强，中文表现优秀
# 3. Qwen/Qwen2.5-Math-72B-Instruct - 数学专用模型
# 4. THUDM/glm-4-9b-chat - 国产模型，数学能力不错
LLM_MODEL=deepseek-ai/DeepSeek-R1

# 温度参数: 数学辅导建议低温度(0.3-0.5)保证确定性
# 0.0 = 完全确定性, 1.0 = 完全随机
TEMPERATURE=0.3

# 最大token数: 数学题需要详细推导，建议4096-8192
MAX_TOKENS=4096

# 🎯 视觉模型配置 - 图片识题
# 推荐选项:
# 1. Qwen/Qwen2-VL-72B-Instruct - 最强视觉理解 ⭐推荐
# 2. OpenGVLab/InternVL2-26B - 性价比高
VISION_MODEL=Qwen/Qwen2-VL-72B-Instruct

# 🎯 向量模型配置 - RAG检索
# 推荐选项:
# 1. BAAI/bge-large-zh-v1.5 - 中文语义理解最佳 ⭐推荐
# 2. BAAI/bge-m3 - 多语言支持更好
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ============================================
# 备选配置 - 如需切换，取消下方注释
# ============================================
# LLM_MODEL=Qwen/Qwen2.5-Math-72B-Instruct
# LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ============================================
# 其他LLM服务商配置（可选）
# ============================================

# OpenAI官方配置
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# 豆包/火山引擎配置
# VOLC_ACCESS_KEY=your-access-key
# VOLC_SECRET_KEY=your-secret-key
# VOLC_REGION=cn-beijing
# VOLC_ENDPOINT=ark.cn-beijing.volces.com
# VOLC_MODEL=your-model-endpoint
# VOLC_VISION_MODEL=your-vision-model-endpoint
# VOLC_EMBEDDING_MODEL=your-embedding-model-endpoint

# ============================================
# 存储配置
# ============================================

# 向量数据库配置
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=sequence_questions

# 知识图谱配置
KG_PERSIST_DIR=./storage/kg
KG_FILE_NAME=sequence_kg.json

# 文件存储配置
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE=10485760

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs

# 调试模式
VERBOSE=True
