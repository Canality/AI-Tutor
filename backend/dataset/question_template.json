    {
      "id": "C_072",
      "source": "《新高考》P72 例3.9 (2011全国卷理20)",
      "type": "解答",
      "difficulty": 3,
      "estimated_time": 12,
      "has_image": false,
      "image_paths": [],
      "knowledge_points": [
        "构造法求通项",
        "等差数列",
        "裂项相消法",
        "分母有理化",
        "数列不等式证明"
      ],
      "content": "设数列 {a_n} 满足 a_1 = 0 且 1/(1-a_{n+1}) - 1/(1-a_n) = 1。\\n(I) 求 {a_n} 的通项公式；\\n(II) 设 b_n = (1-√a_{n+1})/√n，S_n 为 {b_n} 的前 n 项和，证明：S_n < 1。",
      "answer": {
        "part_I": "a_n = 1 - 1/n，n ∈ N*",
        "part_II": "证明见解析"
      },
      "solution_steps": [
        {
          "step_number": 1,
          "title": "构造新数列",
          "content": "令 c_n = 1/(1-a_n)，则递推式变为：c_{n+1} - c_n = 1",
          "key_insight": "把 1/(1-a_n) 看作新数列的第 n 项"
        },
        {
          "step_number": 2,
          "title": "识别等差数列",
          "content": "{c_n} 是以 1 为公差的等差数列",
          "key_insight": "变成 c_{n+1} - c_n = 1，是等差数列"
        },
        {
          "step_number": 3,
          "title": "求首项",
          "content": "c_1 = 1/(1-a_1) = 1/(1-0) = 1",
          "key_insight": "等差数列需要知道首项"
        },
        {
          "step_number": 4,
          "title": "求 c_n 通项",
          "content": "c_n = c_1 + (n-1)·1 = 1 + (n-1) = n",
          "key_insight": "等差数列通项公式"
        },
        {
          "step_number": 5,
          "title": "回代求 a_n",
          "content": "由 c_n = 1/(1-a_n) = n，得：1 - a_n = 1/n，所以 a_n = 1 - 1/n",
          "key_insight": "解方程 1/(1-a_n) = n"
        },
        {
          "step_number": 6,
          "title": "求 a_{n+1}",
          "content": "a_{n+1} = 1 - 1/(n+1) = n/(n+1)",
          "key_insight": "代入通项公式"
        },
        {
          "step_number": 7,
          "title": "化简 b_n",
          "content": "b_n = (1-√(n/(n+1)))/√n = (√(n+1) - √n)/(√n·√(n+1))",
          "key_insight": "分子分母同乘 √(n+1)"
        },
        {
          "step_number": 8,
          "title": "裂项变形",
          "content": "b_n = 1/√n - 1/√(n+1)",
          "key_insight": "拆成两个分式之差"
        },
        {
          "step_number": 9,
          "title": "裂项相消求和",
          "content": "S_n = Σ(1/√k - 1/√(k+1)) = 1 - 1/√(n+1)",
          "key_insight": "中间项全部抵消，只剩首项和末项"
        },
        {
          "step_number": 10,
          "title": "证明不等式",
          "content": "因为 n ≥ 1，所以 √(n+1) > 1，所以 1/√(n+1) > 0，因此 S_n = 1 - 1/√(n+1) < 1",
          "key_insight": "利用 1/√(n+1) > 0"
        }
      ],
      "teaching_guidance": [
        {
          "step": 1,
          "prompt": "观察递推式 1/(1-a_{n+1}) - 1/(1-a_n) = 1，你觉得哪个部分可以看作一个整体？",
          "hint": "把 1/(1-a_n) 看作新数列的第 n 项",
          "expected_answer": "令 c_n = 1/(1-a_n)"
        },
        {
          "step": 2,
          "prompt": "如果令 c_n = 1/(1-a_n)，那么递推式变成了什么形式？这是什么数列？",
          "hint": "变成 c_{n+1} - c_n = 1",
          "expected_answer": "c_{n+1} - c_n = 1，等差数列"
        }
      ],
