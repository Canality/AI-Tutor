      "knowledge_points": ["数列不等式证明", "裂项放缩法", "分式裂项", "放缩技巧"],
      "content": "求证：$\\sum_{k=2}^{n} \\frac{1}{k^2} < 1 - \\frac{1}{n}$（$n \\geq 2$，$n \\in \\mathbb{N}^*$）",
      "content_plain": "求证：从k=2到n的1/k^2的和小于1-1/n（n≥2，n为自然数）",
      "parts": [
        {
          "part_id": "main",
          "title": "证明不等式",
          "answer": "证明见解析",
          "solution": "利用裂项放缩法，将1/k^2放缩为1/(k(k-1))=1/(k-1)-1/k，然后求和"
        }
      ],
      "solution_steps": [
        {
          "step_number": 1,
          "title": "分析通项",
          "content": "需要证明 Σ(1/k^2) < 1 - 1/n",
          "key_insight": "左边是前n项和，右边可以看作是裂项相消的结果"
        },
        {
          "step_number": 2,
          "title": "放缩通项",
          "content": "对于k≥2，1/k^2 < 1/(k(k-1)) = 1/(k-1) - 1/k",
          "key_insight": "分母变小，分式值变大"
        },
        {
          "step_number": 3,
          "title": "求和",
          "content": "Σ(1/k^2) < 1/4 + Σ(1/(k-1) - 1/k) = 1/4 + (1 - 1/n) < 1 - 1/n",
          "key_insight": "裂项相消，中间项全部抵消"
        }
      ],
      "teaching_guidance": [
        {
          "step": 1,
          "prompt": "观察不等式左边是平方倒数和，右边是1-1/n，你想到了什么？",
          "hint": "右边可以看作是裂项相消的结果",
          "expected_answer": "考虑用裂项相消法"
        },
        {
          "step": 2,
          "prompt": "如何放缩1/k^2使其能裂项？",
          "hint": "让分母可以因式分解",
          "expected_answer": "1/k^2 < 1/(k(k-1))"
        }
      ],
